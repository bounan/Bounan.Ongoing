{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "third-party/**"
  ],
  "workspaces": {
    "packages/app": {
      "entry": [
        "src/handlers/*/handler.ts",
        "src/**/*.spec.ts"
      ],
      "ignoreDependencies": [
        "@aws-sdk/client-ssm"
      ]
    },
    "packages/infra": {
      "entry": "src/app.ts"
    },
    "packages/integration-tests": {
      "entry": "**/*.test.ts"
    }
  }
}